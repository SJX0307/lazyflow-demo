<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LazyFlow · AI 備餐規劃</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; font-family: 'DM Sans', sans-serif; background: #F5F0E8; color: #1A2530; }

  /* HEADER */
  .header {
    background: #1A2530;
    padding: 12px 24px;
    display: flex; align-items: center; gap: 12px;
    height: 52px; flex-shrink: 0;
  }
  .logo-sm {
    width: 30px; height: 30px; border-radius: 7px;
    background: linear-gradient(145deg, #2C3E50, #718096);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .logo-sm .lazy { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 9px; color: #fff; line-height: 1; }
  .logo-sm .flow { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 9px; color: rgba(255,255,255,0.45); line-height: 1; }
  .header-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px; color: #fff; }
  .header-sub { font-size: 11px; color: rgba(255,255,255,0.4); margin-left: auto; letter-spacing: 2px; }

  /* LAYOUT */
  .page { display: flex; flex-direction: column; height: calc(100vh - 52px); overflow: hidden; }

  /* INPUT PANEL */
  .input-panel {
    background: #fff;
    border-bottom: 1px solid #E8E2D8;
    padding: 16px 24px;
    display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap;
    flex-shrink: 0;
  }
  .field { display: flex; flex-direction: column; gap: 5px; }
  .field label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #aaa; }
  .field input, .field select {
    padding: 9px 14px;
    border: 2px solid #E8E2D8;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #1A2530;
    background: #F5F0E8;
    outline: none;
    transition: border-color 0.2s;
  }
  .field input:focus, .field select:focus { border-color: #2C3E50; }
  .field input { width: 220px; }
  .field select { width: 100px; }
  .field-theme input { width: 280px; }

  .generate-btn {
    padding: 11px 24px;
    background: #E85D3A;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .generate-btn:hover { background: #c94d2e; transform: translateY(-1px); }
  .generate-btn:disabled { background: #ccc; cursor: not-allowed; transform: none; }

  /* CONTENT AREA */
  .content { flex: 1; overflow: hidden; display: flex; gap: 0; }

  /* WEEKLY PLAN */
  .plan-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
  }

  .empty-state {
    height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 12px; color: #ccc;
  }
  .empty-state .big { font-family: 'Syne', sans-serif; font-size: 16px; color: #bbb; }
  .empty-state .small { font-size: 13px; color: #ccc; text-align: center; }

  .plan-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .plan-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; color: #1A2530; }
  .plan-meta { font-size: 11px; color: #aaa; letter-spacing: 1px; }

  .week-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
  }

  .day-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E8E2D8;
    overflow: hidden;
    animation: fadeUp 0.4s ease forwards;
    opacity: 0;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .day-header {
    background: #1A2530;
    padding: 8px 10px;
    text-align: center;
  }
  .day-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 11px; color: #fff; }
  .day-date { font-size: 9px; color: rgba(255,255,255,0.45); margin-top: 1px; }

  .meal-block { padding: 8px 10px; border-bottom: 1px solid #F0EBE3; }
  .meal-block:last-child { border-bottom: none; }
  .meal-type {
    font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase;
    color: #E85D3A; font-weight: 700; margin-bottom: 4px;
  }
  .meal-name { font-size: 11px; font-weight: 600; color: #1A2530; line-height: 1.4; }
  .meal-kcal { font-size: 9px; color: #aaa; margin-top: 2px; }
  .meal-tags { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 4px; }
  .meal-tag {
    font-size: 8px; padding: 1px 5px;
    border-radius: 10px; background: #F0EBE3; color: #888;
  }

  /* GROCERY PANEL */
  .grocery-panel {
    width: 260px;
    background: #fff;
    border-left: 1px solid #E8E2D8;
    display: flex; flex-direction: column;
    flex-shrink: 0;
    overflow: hidden;
  }
  .grocery-header {
    padding: 14px 16px;
    border-bottom: 1px solid #E8E2D8;
    display: flex; align-items: center; justify-content: space-between;
  }
  .grocery-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; }
  .grocery-count {
    font-size: 10px; background: #E85D3A; color: #fff;
    padding: 2px 7px; border-radius: 10px;
  }
  .grocery-list { flex: 1; overflow-y: auto; padding: 12px 16px; }
  .grocery-category { margin-bottom: 14px; }
  .grocery-cat-label {
    font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
    color: #aaa; margin-bottom: 6px; font-weight: 700;
  }
  .grocery-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 5px 0;
    border-bottom: 1px solid #F5F0E8;
    font-size: 12px;
  }
  .grocery-item:last-child { border-bottom: none; }
  .grocery-item-name { color: #1A2530; }
  .grocery-item-qty { color: #E85D3A; font-weight: 700; font-size: 11px; }

  /* LOADING */
  .loading { display: none; align-items: center; gap: 8px; font-size: 13px; color: #888; }
  .loading.active { display: flex; }
  .spinner {
    width: 16px; height: 16px;
    border: 2px solid #E8E2D8;
    border-top-color: #E85D3A;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* MOBILE */
  @media (max-width: 640px) {
    .header-sub { display: none; }
    .input-panel { padding: 12px 16px; gap: 8px; }
    .field input, .field-theme input { width: 100%; }
    .field select { width: 80px; }
    .generate-btn { width: 100%; }
    .content { flex-direction: column; }
    .grocery-panel { width: 100%; height: 220px; border-left: none; border-top: 1px solid #E8E2D8; }
    .week-grid { grid-template-columns: repeat(2, 1fr); }
    .plan-area { padding: 14px 16px; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="logo-sm"><div class="lazy">Lazy</div><div class="flow">Flow</div></div>
  <div class="header-title">AI 備餐規劃</div>
  <div class="header-sub">MEAL PLANNER</div>
</div>

<div class="page">
  <div class="input-panel">
    <div class="field field-theme">
      <label>本週主題</label>
      <input id="themeInput" placeholder="例如：地中海風、低醣、日式家常..." />
    </div>
    <div class="field">
      <label>人數</label>
      <input id="servingsInput" type="number" min="1" max="10" value="2" style="width:80px" />
    </div>
    <div class="loading" id="loading"><div class="spinner"></div>AI 生成中...</div>
    <button class="generate-btn" id="generateBtn" onclick="generatePlan()">生成本週食譜 ✦</button>
  </div>

  <div class="content">
    <div class="plan-area" id="planArea">
      <div class="empty-state" id="emptyState">
        <div style="font-size:40px;">🥗</div>
        <div class="big">輸入主題開始規劃</div>
        <div class="small">AI 自動生成一週午晚餐<br>並計算備料清單</div>
      </div>
      <div id="planContent" style="display:none">
        <div class="plan-header">
          <div class="plan-title" id="planTitle"></div>
          <div class="plan-meta" id="planMeta"></div>
        </div>
        <div class="week-grid" id="weekGrid"></div>
      </div>
    </div>

    <div class="grocery-panel" id="groceryPanel" style="display:none">
      <div class="grocery-header">
        <div class="grocery-title">🛒 備料清單</div>
        <div class="grocery-count" id="groceryCount">0 項</div>
      </div>
      <div class="grocery-list" id="groceryList"></div>
    </div>
  </div>
</div>

<script>
const DAYS = ['週一','週二','週三','週四','週五','週六','週日'];
const MEALS = ['午餐','晚餐'];

async function generatePlan() {
  const theme = document.getElementById('themeInput').value.trim();
  const servings = document.getElementById('servingsInput').value || 2;
  if (!theme) { document.getElementById('themeInput').focus(); return; }

  const btn = document.getElementById('generateBtn');
  const loading = document.getElementById('loading');
  btn.disabled = true;
  btn.style.display = 'none';
  loading.classList.add('active');

  try {
    const prompt = `你是一位營養師，請為 ${servings} 人規劃一週（週一到週日）的「${theme}」主題午餐和晚餐。

每道餐點請包含：
- 菜名（繁體中文）
- 熱量（大約kcal）
- 2-3個食材標籤

最後列出所有食材的備料清單，按類別分組（蛋白質、蔬菜、主食、調味料），每項列出份量（${servings}人份）。

請只回傳 JSON，格式如下：
{
  "theme": "主題名稱",
  "days": [
    {
      "day": "週一",
      "lunch": { "name": "菜名", "kcal": 500, "tags": ["標籤1","標籤2"] },
      "dinner": { "name": "菜名", "kcal": 600, "tags": ["標籤1","標籤2"] }
    }
  ],
  "grocery": {
    "蛋白質": [{"name":"食材","qty":"份量"}],
    "蔬菜": [{"name":"食材","qty":"份量"}],
    "主食": [{"name":"食材","qty":"份量"}],
    "調味料": [{"name":"食材","qty":"份量"}]
  }
}`;

    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await res.json();
    const text = data.content.map(i => i.text || '').join('');
    const clean = text.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);
    renderPlan(parsed, servings);
  } catch(e) {
    alert('生成失敗，請再試一次');
  } finally {
    btn.disabled = false;
    btn.style.display = '';
    loading.classList.remove('active');
  }
}

function renderPlan(data, servings) {
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('planContent').style.display = 'block';
  document.getElementById('groceryPanel').style.display = 'flex';

  document.getElementById('planTitle').textContent = data.theme + ' 週計畫';
  document.getElementById('planMeta').textContent = servings + ' 人份 · 午餐 + 晚餐';

  const grid = document.getElementById('weekGrid');
  grid.innerHTML = '';

  data.days.forEach((day, i) => {
    const card = document.createElement('div');
    card.className = 'day-card';
    card.style.animationDelay = (i * 0.06) + 's';
    card.innerHTML = `
      <div class="day-header">
        <div class="day-name">${day.day}</div>
      </div>
      <div class="meal-block">
        <div class="meal-type">午餐</div>
        <div class="meal-name">${day.lunch.name}</div>
        <div class="meal-kcal">${day.lunch.kcal} kcal</div>
        <div class="meal-tags">${(day.lunch.tags||[]).map(t=>`<span class="meal-tag">${t}</span>`).join('')}</div>
      </div>
      <div class="meal-block">
        <div class="meal-type">晚餐</div>
        <div class="meal-name">${day.dinner.name}</div>
        <div class="meal-kcal">${day.dinner.kcal} kcal</div>
        <div class="meal-tags">${(day.dinner.tags||[]).map(t=>`<span class="meal-tag">${t}</span>`).join('')}</div>
      </div>
    `;
    grid.appendChild(card);
  });

  // Grocery
  const groceryList = document.getElementById('groceryList');
  groceryList.innerHTML = '';
  let totalItems = 0;
  for (const [cat, items] of Object.entries(data.grocery)) {
    if (!items || items.length === 0) continue;
    totalItems += items.length;
    const section = document.createElement('div');
    section.className = 'grocery-category';
    section.innerHTML = `<div class="grocery-cat-label">${cat}</div>` +
      items.map(item => `
        <div class="grocery-item">
          <span class="grocery-item-name">${item.name}</span>
          <span class="grocery-item-qty">${item.qty}</span>
        </div>`).join('');
    groceryList.appendChild(section);
  }
  document.getElementById('groceryCount').textContent = totalItems + ' 項';
}

document.getElementById('themeInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') generatePlan();
});
</script>
</body>
</html>
